{
  "manifest_version": 3,
  "name": "WLO Metadaten-Agent",
  "version": "2.0.0",
  "description": "KI-gestützte Metadaten-Erfassung für WirLernenOnline — mit integrierter Webkomponente und FastAPI-Backend.",
  "homepage_url": "https://wirlernenonline.de/",
  
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "notifications",
    "sidePanel",
    "contextMenus"
  ],
  
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "WLO Metadaten-Agent"
  },
  
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  
  "background": {
    "service_worker": "background/background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://suche.wirlernenonline.de/*",
        "https://*.wirlernenonline.de/*"
      ],
      "js": ["content/wlo-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://suche.wirlernenonline.de/*",
        "https://*.wirlernenonline.de/*"
      ],
      "js": ["content/wlo-overlay.js"],
      "run_at": "document_idle"
    }
  ],
  
  "options_page": "options/options.html",
  
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "images/*", "webcomponent/*", "config.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
